---
import { getCollection } from "astro:content";

const articles = (await getCollection("blog")).sort(
  (a, b) => b.data.timestamp.valueOf() - a.data.timestamp.valueOf(),
);

const byYear: { year: number; posts: { title: string; url: string; month: string }[] }[] = [];
for (const article of articles) {
  const year = article.data.timestamp.getFullYear();
  let yearGroup = byYear.find((g) => g.year === year);
  if (!yearGroup) {
    yearGroup = { year, posts: [] };
    byYear.push(yearGroup);
  }
  const month = article.data.timestamp.toLocaleString("default", { month: "short" });
  yearGroup.posts.push({
    title: article.data.title,
    url: `/posts/${article.data.slug}`,
    month,
  });
}
---

<nav class="text-sm">
  <h2 class="font-display text-base tracking-wider mb-4 zag-text-muted">Archives</h2>
  <ul class="flex flex-col gap-5">
    {byYear.map((group) => (
      <li>
        <h3 class="font-semibold mb-2">{group.year}</h3>
        <ul class="flex flex-col gap-1.5">
          {group.posts.map((post) => (
            <li>
              <a
                href={post.url}
                class="no-underline hover:underline zag-offset leading-snug block"
              >
                <span class="text-xs zag-text-muted">{post.month}</span>
                <br />
                <span>{post.title}</span>
              </a>
            </li>
          ))}
        </ul>
      </li>
    ))}
  </ul>
</nav>
