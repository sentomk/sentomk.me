---
import { getConfigurationCollection } from "../lib/utils";
import Anchor from "./common/Anchor.astro";
import ThemeToggle from "./ThemeToggle.astro";

const { data: config } = await getConfigurationCollection();
---

<header class="zag-bg zag-border-b zag-transition sticky top-0 w-full z-10">
  <div
    class="zag-bg zag-transition md:hidden relative z-50 py-4 flex items-center"
  >
    <button id="nav-toggle" class="px-4" type="button" aria-label="Toggle navigation menu">
      <svg
        xmlns="http://www.w3.org/2000/svg"
        width="32"
        height="32"
        viewBox="0 0 512 512"
        class="zag-fill zag-transition"
      >
        <title>Navigation menu</title>
        <path d="M80 96h352v32H80zm0 144h352v32H80zm0 144h352v32H80z"></path>
      </svg>
    </button>
  </div>
  <nav
    class="zag-bg zag-border-b zag-transition fixed md:relative inset-x-0 top-0 h-auto md:px-4 flex justify-between flex-col gap-8 py-4 text-xl md:flex-row max-w-5xl mx-auto md:pt-4 md:border-none w-full"
  >
    <div
      class="flex flex-col font-mono font-medium gap-4 md:flex-row px-4 md:px-0 mt-16 md:mt-0"
    >
      {
        Object.entries(config.menu).map((i) => (
          <Anchor url={i[1]}>{i[0]}</Anchor>
        ))
      }
    </div>
    <div class="flex gap-4 items-center px-4 md:px-0">
      <a href="/archives" aria-label="Archives" class="inline-flex">
        <svg width="28" height="28" viewBox="0 0 24 24" class="zag-fill zag-transition">
          <title>Archives</title>
          <path d="M21 3H3v4h18V3zm-2 6H5v12h14V9zm-8 3h4v2h-4v-2z"/>
        </svg>
      </a>
      <a href="/rss.xml" target="_blank" aria-label="RSS Feed" class="inline-flex">
        <svg width="30" height="30" viewBox="0 0 24 24" class="zag-fill zag-transition">
          <title>RSS Feed</title>
          <path d="M6.18 15.64a2.18 2.18 0 0 1 2.18 2.18C8.36 19 7.38 20 6.18 20C5 20 4 19 4 17.82a2.18 2.18 0 0 1 2.18-2.18M4 4.44A15.56 15.56 0 0 1 19.56 20h-2.83A12.73 12.73 0 0 0 4 7.27V4.44m0 5.66a9.9 9.9 0 0 1 9.9 9.9h-2.83A7.07 7.07 0 0 0 4 12.93V10.1Z"/>
        </svg>
      </a>
      <ThemeToggle />
    </div>
  </nav>
</header>

<script>
  const button = document.getElementById("nav-toggle") as HTMLButtonElement;
  const nav = document.querySelector("nav") as HTMLElement;
  let isOpen = false;

  function updateNavState() {
    const isMobile = window.matchMedia("(max-width: 767px)").matches;
    if (isMobile) {
      nav.style.transform = isOpen ? "translateY(0)" : "translateY(-100%)";
    } else {
      nav.style.transform = "translateY(0)";
      isOpen = false;
    }
  }

  function toggleNav() {
    isOpen = !isOpen;
    updateNavState();
  }

  button?.addEventListener("click", toggleNav);
  window.addEventListener("resize", updateNavState);

  updateNavState();
</script>
