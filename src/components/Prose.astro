---
type Props = {
  class?: string;
};

const { class: customClass } = Astro.props;
---

<div
  class="w-full font-sans prose prose-headings:font-sans prose-img:rounded-none prose-p:text-(--color-zag-dark) prose-p:dark:text-(--color-zag-light)  prose-a:underline-offset-4 prose-h1:text-2xl prose-a:text-(--color-zag-dark) dark:prose-a:text-(--color-zag-light) prose-headings:text-(--color-zag-dark) prose-headings:dark:text-(--color-zag-light) prose-p:text-justify prose-code:text-(--color-zag-dark) dark:prose-code:text-(--color-zag-light) prose-h2:text-2xl prose-h3:text-xl prose-h4:text-lg prose-h5:text-base prose-h6:text-sm prose-strong:text-(--color-zag-dark) dark:prose-strong:text-(--color-zag-light) prose-li:text-(--color-zag-dark) dark:prose-li:text-(--color-zag-light) prose-ul:marker:text-(--color-zag-dark) prose-ul:dark:marker:text-(--color-zag-light) prose-ol:marker:text-(--color-zag-dark) prose-ol:dark:marker:text-(--color-zag-light) prose-a:offset-(--zag-offset) prose-a:focus:outline-2 prose-a:focus:outline-offset-2 prose-a:focus:outline-zag-dark prose-a:dark:focus:outline-zag-light"
  class:list={customClass ? [customClass] : []}
>
  <slot />
</div>

<script is:inline>
  document.querySelectorAll("pre > code").forEach((code) => {
    const pre = code.parentElement;
    pre.style.position = "relative";

    const btn = document.createElement("button");
    btn.textContent = "Copy";
    btn.style.cssText = "position:absolute;top:6px;right:6px;border:none;background:none;font-family:inherit;font-size:12px;cursor:pointer;opacity:0;transition:opacity .15s;padding:2px 6px;";
    btn.className = "zag-text-muted zag-transition";

    pre.appendChild(btn);
    pre.addEventListener("mouseenter", () => btn.style.opacity = "1");
    pre.addEventListener("mouseleave", () => btn.style.opacity = "0");

    btn.addEventListener("click", () => {
      navigator.clipboard.writeText(code.textContent).then(() => {
        btn.textContent = "Copied";
        setTimeout(() => btn.textContent = "Copy", 1500);
      });
    });
  });
</script>
