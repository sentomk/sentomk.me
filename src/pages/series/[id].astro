---
import { getCollection, render } from "astro:content";
import Section from "../../components/common/Section.astro";
import Layout from "../../layouts/Layout.astro";
import Prose from "../../components/Prose.astro";
import { getConfigurationCollection, processArticleDate } from "../../lib/utils";

export async function getStaticPaths() {
	const seriesEntries = await getCollection("series");
	const allPosts = await getCollection("blog");
	const { data: config } = await getConfigurationCollection();

	return seriesEntries.map((s) => {
		const postsInSeries = allPosts
			.filter((post) => post.data.series === s.data.slug)
			.sort((a, b) => a.data.timestamp.valueOf() - b.data.timestamp.valueOf());

		return {
			params: { id: s.data.slug },
			props: {
				series: {
					...s,
					data: {
						...s.data,
						url: `${config.site.baseUrl}/series/${s.data.slug}`,
					},
				},
				posts: postsInSeries,
			},
		};
	});
}

const { series, posts } = Astro.props;
const { Content } = await render(series);
const { data: config } = await getConfigurationCollection();
---

<Layout>
  <Fragment slot="head">
    <title>{`${series.data.title} • ${config.personal.name}`}</title>
    <meta
      name="description"
      content={series.data.longDescription ?? series.data.description}
    />
    <meta property="og:title" content={`${series.data.title} • ${config.personal.name}`} />
    <meta property="og:description" content={series.data.description} />
    {series.data.tags && (
      <meta name="keywords" content={series.data.tags.join(", ")} />
    )}
    {series.data.cardImage && (
      <meta property="og:image" content={series.data.cardImage} />
    )}
    <meta property="og:url" content={`${config.site.baseUrl}/series/${series.data.slug}`} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={`${series.data.title} • ${config.personal.name}`} />
    <meta name="twitter:description" content={series.data.description} />
    {series.data.cardImage && (
      <meta name="twitter:image" content={series.data.cardImage} />
    )}
    <meta http-equiv="content-language" content="en" />
    <meta name="language" content="English" />
    <link rel="canonical" href={`${config.site.baseUrl}/series/${series.data.slug}`} />
  </Fragment>
  <Section class="mt-8">
    <!-- Series header -->
    <div class="flex flex-col gap-4 mt-8 mb-12">
      <h1 class="text-3xl sm:text-4xl leading-tight font-display">
        {series.data.title}
      </h1>
      <div class="flex flex-wrap text-sm gap-2">
        {series.data.tags
          ? series.data.tags.map((tag) => (
              <span class="text-xs font-mono zag-text-muted">#{tag}</span>
            ))
          : null}
      </div>
      <Prose>
        <Content />
      </Prose>
    </div>

    <!-- Posts list -->
    {posts.length > 0 && (
      <div class="zag-border-b zag-transition pb-1 mb-8"></div>
    )}
    <ul class="flex flex-col gap-10">
      {posts.map((post) => (
        <li>
          <a href={`/blog/${post.data.slug}`} class="group block no-underline">
            <span class="font-mono font-medium text-base sm:text-lg group-hover:underline zag-offset">
              {post.data.title}
            </span>
            <p class="font-mono text-sm zag-text-muted mt-1.5 leading-relaxed">
              {post.data.description}
            </p>
            <div class="flex gap-2 mt-3 flex-wrap">
              {post.data.tags?.map((tag) => (
                <span class="text-[0.55rem] font-display tracking-widest px-2 py-1 border zag-text-muted">{tag}</span>
              ))}
            </div>
          </a>
        </li>
      ))}
    </ul>
  </Section>
</Layout>
