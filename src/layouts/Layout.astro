---
import Archives from "../components/Archives.astro";
import Footer from "../components/Footer.astro";
import Header from "../components/Header.astro";
import "../styles/global.css";
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="icon" type="image/png" sizes="32x32" href="/favicon-32.png" />
    <link rel="icon" type="image/png" sizes="16x16" href="/favicon-16.png" />
    <meta name="generator" content={Astro.generator} />
    <link rel="preconnect" href="https://fonts.bunny.net" />
    <link
      href="https://fonts.bunny.net/css?family=source-serif-4:400,400i,500,500i,600,600i,700,700i|ibm-plex-mono:400,400i,500,500i,600,600i,700,700i"
      rel="stylesheet"
    />
    
    <!-- Theme detection script - runs before page renders -->
    <script is:inline>
      const theme = (() => {
        if (typeof localStorage !== "undefined" && localStorage.getItem("theme")) {
          return localStorage.getItem("theme") ?? "light";
        }
        if (window.matchMedia("(prefers-color-scheme: dark)").matches) {
          return "dark";
        }
        return "light";
      })();

      if (theme === "light") {
        document.documentElement.classList.remove("dark");
      } else {
        document.documentElement.classList.add("dark");
      }

      window.localStorage.setItem("theme", theme);
    </script>
    
    <slot name="head" />
  </head>
  <body class="zag-bg zag-text zag-transition font-sans">
    <Header />
    <main
      class="lg:grid max-w-5xl mx-auto lg:px-4 lg:gap-x-8"
      style="grid-template-columns: 1fr 220px; grid-template-areas: 'fullwidth fullwidth' 'content archives';"
    >
      <div style="grid-area: fullwidth">
        <slot name="fullwidth" />
      </div>
      <div style="grid-area: content" class="min-w-0">
        <slot />
      </div>
      <aside style="grid-area: archives" class="hidden lg:block">
        <div class="sticky top-20 pt-4">
          <Archives />
        </div>
      </aside>
    </main>
    <Footer />
  </body>
</html>
